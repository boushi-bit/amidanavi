  { "id": 268, "text": "舎利弗、北方世界、", "ruby": "しゃりほつ ほっぽうせかい", "duration": 4.0, "type": "all" },
  { "id": 269, "text": "有焔肩佛・最勝音佛・", "ruby": "うえんけんぶつ さいしょうおんぶつ", "duration": 4.5, "type": "all" },
  { "id": 270, "text": "難沮佛・日生佛・網明佛、", "ruby": "なんしょぶつ にっしょうぶつ もうみょうぶつ", "duration": 5.0, "type": "all" },
  { "id": 271, "text": "如是等恒河沙数諸佛、", "ruby": "にょぜとうごうがしゃしゅしょぶつ", "duration": 5.0, "type": "all" },
