  { "id": 156, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 157, "text": "於汝意云何。", "ruby": "おにょいうんが", "duration": 3.5, "type": "all" },
  { "id": 158, "text": "彼佛何故", "ruby": "ひぶがこ", "duration": 3.0, "type": "all" },
  { "id": 159, "text": "號阿彌陀。", "ruby": "ごうあみだ", "duration": 3.0, "type": "all" },
