  { "id": 295, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 296, "text": "於汝意云何。", "ruby": "おにょいうんが", "duration": 3.5, "type": "all" },
  { "id": 297, "text": "何故名爲", "ruby": "がこみょうい", "duration": 3.0, "type": "all" },
  { "id": 298, "text": "一切諸佛所護念経。", "ruby": "いっさいしょぶつしょごねんぎょう", "duration": 5.0, "type": "all" },
  { "id": 299, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 300, "text": "若有善男子・善女人、", "ruby": "にゃくうぜんなんし ぜんにょにん", "duration": 5.0, "type": "all" },
  { "id": 301, "text": "聞是諸佛所説名", "ruby": "もんぜしょぶっしょせつみょう", "duration": 4.0, "type": "all" },
  { "id": 302, "text": "及経名者、", "ruby": "ぎゅうきょうみょうしゃ", "duration": 3.0, "type": "all" },
  { "id": 303, "text": "是諸善男子・善女人、", "ruby": "ぜしょぜんなんし ぜんにょにん", "duration": 5.0, "type": "all" },
  { "id": 304, "text": "皆爲一切諸佛", "ruby": "かいいいっさいしょぶつ", "duration": 4.0, "type": "all" },
  { "id": 305, "text": "共所護念、", "ruby": "ぐしょごねん", "duration": 3.0, "type": "all" },
  { "id": 306, "text": "皆得不退転", "ruby": "かいとくふたいてん", "duration": 3.5, "type": "all" },
  { "id": 307, "text": "於阿耨多羅", "ruby": "おあのくたら", "duration": 3.0, "type": "all" },
  { "id": 308, "text": "三藐三菩提。", "ruby": "さんみゃくさんぼだい", "duration": 3.5, "type": "all" },
  { "id": 309, "text": "是故舎利弗、", "ruby": "ぜこしゃりほつ", "duration": 3.0, "type": "all" },
  { "id": 310, "text": "汝等皆當", "ruby": "にょとうかいとう", "duration": 3.0, "type": "all" },
  { "id": 311, "text": "信受我語", "ruby": "しんじゅがご", "duration": 3.0, "type": "all" },
  { "id": 312, "text": "及諸佛所説。", "ruby": "ぎっしょぶっしょせつ", "duration": 3.5, "type": "all" },
  { "id": 313, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 314, "text": "若有人、", "ruby": "にゃくうにん", "duration": 2.5, "type": "all" },
  { "id": 315, "text": "已發願、今發願、當發願、", "ruby": "いほつがん こんほつがん とうほつがん", "duration": 5.0, "type": "all" },
  { "id": 316, "text": "欲生阿彌陀佛国者、", "ruby": "よくしょうあみだぶっこくしゃ", "duration": 4.5, "type": "all" },
  { "id": 317, "text": "是諸人等、", "ruby": "ぜしょにんとう", "duration": 3.0, "type": "all" },
  { "id": 318, "text": "皆得不退転", "ruby": "かいとくふたいてん", "duration": 3.5, "type": "all" },
  { "id": 319, "text": "於阿耨多羅三藐三菩提、", "ruby": "おあのくたらさんみゃくさんぼだい", "duration": 5.0, "type": "all" },
  { "id": 320, "text": "於彼国土、", "ruby": "おひこくど", "duration": 3.0, "type": "all" },
  { "id": 321, "text": "若已生、若今生、若當生。", "ruby": "にゃくいしょう にゃくこんじょう にゃくとうしょう", "duration": 5.0, "type": "all" },
  { "id": 322, "text": "是故舎利弗、", "ruby": "ぜこしゃりほつ", "duration": 3.0, "type": "all" },
  { "id": 323, "text": "諸善男子・善女人、", "ruby": "しょぜんなんし ぜんにょにん", "duration": 4.0, "type": "all" },
  { "id": 324, "text": "若有信者、", "ruby": "にゃくうしんじゃ", "duration": 3.0, "type": "all" },
  { "id": 325, "text": "應當發願", "ruby": "おうとうほつがん", "duration": 3.0, "type": "all" },
  { "id": 326, "text": "生彼国土。", "ruby": "しょひこくど", "duration": 3.0, "type": "all" },
  { "id": 327, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 328, "text": "如我今者", "ruby": "にょがこんじゃ", "duration": 3.0, "type": "all" },
  { "id": 329, "text": "稱讚諸佛不可思議功徳、", "ruby": "しょうさんしょぶつふかしぎくどく", "duration": 5.5, "type": "all" },
  { "id": 330, "text": "彼諸佛等、", "ruby": "ひしょぶっとう", "duration": 3.0, "type": "all" },
  { "id": 331, "text": "亦稱説我不可思議功徳、", "ruby": "やくしょうせつがふかしぎくどく", "duration": 5.5, "type": "all" },
  { "id": 332, "text": "而作是言。", "ruby": "にさぜごん", "duration": 3.0, "type": "all" },
  { "id": 333, "text": "釋迦牟尼佛、", "ruby": "しゃかむにぶつ", "duration": 3.5, "type": "all" },
  { "id": 334, "text": "能爲甚難希有之事、", "ruby": "のういじんなんけうしじ", "duration": 5.0, "type": "all" },
  { "id": 335, "text": "能於娑婆国土", "ruby": "のうおしゃばこくど", "duration": 3.5, "type": "all" },
  { "id": 336, "text": "五濁悪世、", "ruby": "ごじょくあくせ", "duration": 3.0, "type": "all" },
  { "id": 337, "text": "劫濁・見濁・煩悩濁・", "ruby": "こうじょく けんじょく ぼんのうじょく", "duration": 4.5, "type": "all" },
  { "id": 338, "text": "衆生濁・命濁中、", "ruby": "しゅじょうじょく みょうじょくちゅう", "duration": 4.0, "type": "all" },
  { "id": 339, "text": "得阿耨多羅三藐三菩提、", "ruby": "とくあのくたらさんみゃくさんぼだい", "duration": 5.0, "type": "all" },
  { "id": 340, "text": "爲諸衆生、", "ruby": "いしょしゅじょう", "duration": 3.0, "type": "all" },
  { "id": 341, "text": "説是一切世間", "ruby": "せつぜいっさいせけん", "duration": 3.5, "type": "all" },
  { "id": 342, "text": "難信之法。", "ruby": "なんしんしほう", "duration": 3.0, "type": "all" },
  { "id": 343, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 344, "text": "當知我於五濁悪世", "ruby": "とうちがおごじょくあくせ", "duration": 4.5, "type": "all" },
  { "id": 345, "text": "行此難事、", "ruby": "ぎょうしなんじ", "duration": 3.0, "type": "all" },
  { "id": 346, "text": "得阿耨多羅三藐三菩提、", "ruby": "とくあのくたらさんみゃくさんぼだい", "duration": 5.0, "type": "all" },
  { "id": 347, "text": "爲一切世間、", "ruby": "いいっさいせけん", "duration": 3.5, "type": "all" },
  { "id": 348, "text": "説此難信之法。", "ruby": "せっしなんしんしほう", "duration": 4.0, "type": "all" },
  { "id": 349, "text": "是爲甚難。", "ruby": "ぜいじんなん", "duration": 6.0, "type": "slow" },
  { "id": 350, "text": "佛説此経已、", "ruby": "ぶっせつしきょうい", "duration": 4.0, "type": "all" },
  { "id": 351, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 352, "text": "及諸比丘、", "ruby": "ぎっしょびく", "duration": 3.0, "type": "all" },
  { "id": 353, "text": "一切世間", "ruby": "いっさいせけん", "duration": 3.0, "type": "all" },
  { "id": 354, "text": "天・人・阿修羅等、", "ruby": "てん にん あしゅらとう", "duration": 4.0, "type": "all" },
  { "id": 355, "text": "聞佛所説、", "ruby": "もんぶつしょせつ", "duration": 3.0, "type": "all" },
  { "id": 356, "text": "歓喜信受、", "ruby": "かんぎしんじゅ", "duration": 3.0, "type": "all" },
  { "id": 357, "text": "作禮而去。", "ruby": "さらいにこ", "duration": 10.0, "type": "slow" },
  { "id": 358, "text": "仏説阿弥陀経", "ruby": "ぶっせつあみだきょう", "duration": 10.0, "type": "slow" }
]
