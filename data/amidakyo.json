  { "id": 276, "text": "舎利弗、下方世界、", "ruby": "しゃりほつ げほうせかい", "duration": 4.0, "type": "all" },
  { "id": 277, "text": "有師子佛・名聞佛・名光佛・", "ruby": "うししぶつ みょうもんぶつ みょうこうぶつ", "duration": 5.0, "type": "all" },
  { "id": 278, "text": "達摩佛・法幢佛・持法佛、", "ruby": "だつまぶつ ほうどうぶつ じほうぶつ", "duration": 5.0, "type": "all" },
  { "id": 279, "text": "如是等恒河沙数諸佛、", "ruby": "にょぜとうごうがしゃしゅしょぶつ", "duration": 5.0, "type": "all" },
  { "id": 280, "text": "各於其国、出廣長舌相、", "ruby": "かくおごこく すいこうじょうぜっそう", "duration": 5.0, "type": "all" },
  { "id": 281, "text": "徧覆三千大千世界、説誠實言。", "ruby": "へんぷさんぜんだいせんせかい せつじょうじつごん", "duration": 5.5, "type": "all" },
  { "id": 282, "text": "汝等衆生、當信是稱讚", "ruby": "にょとうしゅじょう とうしんぜしょうさん", "duration": 4.5, "type": "all" },
