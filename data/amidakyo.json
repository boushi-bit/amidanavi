[
  { "id": 1, "text": "仏説阿弥陀経", "ruby": "ぶっせつあみだきょう", "duration": 5.0, "type": "solo" },
  { "id": 2, "text": "如是我聞。", "ruby": "にょぜがもん", "duration": 3.0, "type": "all" },
  { "id": 3, "text": "一時仏、在舎衛国", "ruby": "いちじぶつ ざいしゃえこく", "duration": 4.5, "type": "all" },
  { "id": 4, "text": "祇樹給孤独園", "ruby": "ぎじゅきっこどくおん", "duration": 4.0, "type": "all" },
  { "id": 5, "text": "与大比丘衆", "ruby": "よだいびくしゅう", "duration": 3.5, "type": "all" },
  { "id": 6, "text": "千二百五十人倶。", "ruby": "せんにひゃくごじゅうにんく", "duration": 4.0, "type": "all" },
  { "id": 7, "text": "皆是大阿羅漢、", "ruby": "かいぜだいあらかん", "duration": 4.0, "type": "all" },
  { "id": 8, "text": "衆所知識。", "ruby": "しゅしょちしき", "duration": 3.0, "type": "all" },
  { "id": 9, "text": "長老舎利弗", "ruby": "ちょうろうしゃりほつ", "duration": 3.5, "type": "all" },
  { "id": 10, "text": "摩訶目犍連", "ruby": "まかもくけんれん", "duration": 3.5, "type": "all" },
  { "id": 11, "text": "摩訶迦葉", "ruby": "まかかしょう", "duration": 3.0, "type": "all" },
  { "id": 12, "text": "摩訶迦旃延", "ruby": "まかかせんねん", "duration": 3.5, "type": "all" },
  { "id": 13, "text": "摩訶倶犍羅", "ruby": "まかくちら", "duration": 3.5, "type": "all" },
  { "id": 14, "text": "離婆多", "ruby": "りはた", "duration": 2.5, "type": "all" },
  { "id": 15, "text": "周利槃陀伽", "ruby": "しゅうりはんだが", "duration": 3.5, "type": "all" },
  { "id": 16, "text": "難陀", "ruby": "なんだ", "duration": 2.0, "type": "all" },
  { "id": 17, "text": "阿難陀", "ruby": "あなんだ", "duration": 2.5, "type": "all" },
  { "id": 18, "text": "羅睺羅", "ruby": "らごら", "duration": 2.5, "type": "all" },
  { "id": 19, "text": "驕梵波提", "ruby": "きょうぼんはだい", "duration": 3.0, "type": "all" },
  { "id": 20, "text": "賓頭盧頗羅堕", "ruby": "びんずるはらだ", "duration": 4.0, "type": "all" },
  { "id": 21, "text": "迦留陀夷", "ruby": "かるだい", "duration": 3.0, "type": "all" },
  { "id": 22, "text": "摩訶劫賓那", "ruby": "まかこうひんな", "duration": 3.5, "type": "all" },
  { "id": 23, "text": "薄拘羅", "ruby": "はくら", "duration": 2.5, "type": "all" },
  { "id": 24, "text": "阿㝹樓駄、", "ruby": "あぬるだ", "duration": 3.0, "type": "all" },
  { "id": 25, "text": "如是等諸大弟子、", "ruby": "にょぜとうしょだいでし", "duration": 4.0, "type": "all" },
  { "id": 26, "text": "并諸菩薩摩訶薩、", "ruby": "びょうしょぼさつまかさ", "duration": 4.5, "type": "all" },
  { "id": 27, "text": "文殊師利法王子", "ruby": "もんじゅしりほうおうじ", "duration": 4.5, "type": "all" },
  { "id": 28, "text": "阿逸多菩薩", "ruby": "あいったぼさつ", "duration": 3.5, "type": "all" },
  { "id": 29, "text": "乾陀訶提菩薩", "ruby": "けんだかだいぼさつ", "duration": 4.0, "type": "all" },
  { "id": 30, "text": "常精進菩薩、", "ruby": "じょうしょうじんぼさつ", "duration": 3.5, "type": "all" },
  { "id": 31, "text": "与如是等", "ruby": "よにょぜとう", "duration": 3.0, "type": "all" },
  { "id": 32, "text": "諸大菩薩", "ruby": "しょだいぼさつ", "duration": 3.0, "type": "all" },
  { "id": 33, "text": "及釈提桓因等", "ruby": "ぎゅうしゃくだいかんいんとう", "duration": 4.0, "type": "all" },
  { "id": 34, "text": "無量諸天", "ruby": "むりょうしょてん", "duration": 3.0, "type": "all" },
  { "id": 35, "text": "大衆倶。", "ruby": "だいしゅく", "duration": 3.0, "type": "all" },
  { "id": 36, "text": "爾時佛告", "ruby": "にじぶつごう", "duration": 3.0, "type": "all" },
  { "id": 37, "text": "長老舎利弗、", "ruby": "ちょうろうしゃりほつ", "duration": 3.5, "type": "all" },
  { "id": 38, "text": "従是西方、", "ruby": "じゅうぜさいほう", "duration": 3.0, "type": "all" },
  { "id": 39, "text": "過十萬億佛土、", "ruby": "かじゅうまんのくぶつど", "duration": 4.0, "type": "all" },
  { "id": 40, "text": "有世界、", "ruby": "うせかい", "duration": 2.5, "type": "all" },
  { "id": 41, "text": "名曰極楽。", "ruby": "みょうわごくらく", "duration": 3.5, "type": "all" },
  { "id": 42, "text": "其土有佛、", "ruby": "ごどうぶつ", "duration": 3.0, "type": "all" },
  { "id": 43, "text": "號阿彌陀。", "ruby": "ごうあみだ", "duration": 3.0, "type": "all" },
  { "id": 44, "text": "今現在説法。", "ruby": "こんげんざいせっぽう", "duration": 3.5, "type": "all" },
  { "id": 45, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 46, "text": "彼土何故、", "ruby": "ひどがこ", "duration": 3.0, "type": "all" },
  { "id": 47, "text": "名爲極楽。", "ruby": "みょういごくらく", "duration": 3.0, "type": "all" },
  { "id": 48, "text": "其国衆生、", "ruby": "ごこくしゅじょう", "duration": 3.0, "type": "all" },
  { "id": 49, "text": "無有衆苦、", "ruby": "むうしゅく", "duration": 3.0, "type": "all" },
  { "id": 50, "text": "但受諸樂、", "ruby": "たんじゅしょらく", "duration": 3.0, "type": "all" },
  { "id": 51, "text": "故名極楽。", "ruby": "こみょうごくらく", "duration": 3.0, "type": "all" },
  { "id": 52, "text": "又舎利弗、", "ruby": "うしゃりほつ", "duration": 3.0, "type": "all" },
  { "id": 53, "text": "極楽国土、", "ruby": "ごくらーこくど", "duration": 3.0, "type": "all" },
  { "id": 54, "text": "七重欄楯、", "ruby": "しちじゅうらんじゅん", "duration": 3.5, "type": "all" },
  { "id": 55, "text": "七重羅網、", "ruby": "しちじゅうらもう", "duration": 3.0, "type": "all" },
  { "id": 56, "text": "七重行樹。", "ruby": "しちじゅうごうじゅ", "duration": 3.0, "type": "all" },
  { "id": 57, "text": "皆是四寶、", "ruby": "かいぜしほう", "duration": 3.0, "type": "all" },
  { "id": 58, "text": "周匝囲繞。", "ruby": "しゅうそういにょう", "duration": 3.0, "type": "all" },
  { "id": 59, "text": "是故彼国、", "ruby": "ぜこひこく", "duration": 3.0, "type": "all" },
  { "id": 60, "text": "名曰極楽。", "ruby": "みょうわつごくらく", "duration": 3.0, "type": "all" },
  { "id": 61, "text": "又舎利弗、", "ruby": "うしゃりほつ", "duration": 3.0, "type": "all" },
  { "id": 62, "text": "極楽国土、", "ruby": "ごくらーこくど", "duration": 3.0, "type": "all" },
  { "id": 63, "text": "有七寶池。", "ruby": "うしっぽうち", "duration": 3.0, "type": "all" },
  { "id": 64, "text": "八功徳水、", "ruby": "はっくどくすい", "duration": 3.0, "type": "all" },
  { "id": 65, "text": "充満其中。", "ruby": "じゅうまんごちゅう", "duration": 3.0, "type": "all" },
  { "id": 66, "text": "池底純以", "ruby": "ちたいじゅんに", "duration": 3.0, "type": "all" },
  { "id": 67, "text": "金沙布地。", "ruby": "こんしゃふじ", "duration": 3.0, "type": "all" },
  { "id": 68, "text": "四辺階道、", "ruby": "しへんかいどう", "duration": 3.0, "type": "all" },
  { "id": 69, "text": "金・銀・瑠璃・", "ruby": "こん ごん るり", "duration": 3.0, "type": "all" },
  { "id": 70, "text": "玻瓈合成。", "ruby": "はりごうじょう", "duration": 3.0, "type": "all" },
  { "id": 71, "text": "上有楼閣。", "ruby": "じょううろうかく", "duration": 3.0, "type": "all" },
  { "id": 72, "text": "亦以金・銀・瑠璃・", "ruby": "やくいこん ごん るり", "duration": 3.5, "type": "all" },
  { "id": 73, "text": "玻瓈・硨磲・", "ruby": "はり しゃこ", "duration": 3.0, "type": "all" },
  { "id": 74, "text": "赤珠・碼碯、", "ruby": "しゃくしゅ めのう", "duration": 3.0, "type": "all" },
  { "id": 75, "text": "而厳飾之。", "ruby": "にごんじきし", "duration": 3.0, "type": "all" },
  { "id": 76, "text": "池中蓮華、", "ruby": "ちちゅうれんげ", "duration": 3.0, "type": "all" },
  { "id": 77, "text": "大如車輪。", "ruby": "だいにょしゃりん", "duration": 3.0, "type": "all" },
  { "id": 78, "text": "青色青光、", "ruby": "しょうしきしょうこう", "duration": 3.0, "type": "all" },
  { "id": 79, "text": "黄色黄光、", "ruby": "おうしきおうこう", "duration": 3.0, "type": "all" },
  { "id": 80, "text": "赤色赤光、", "ruby": "しゃくしきしゃっこう", "duration": 3.0, "type": "all" },
  { "id": 81, "text": "白色白光、", "ruby": "びゃくしきびゃっこう", "duration": 3.0, "type": "all" },
  { "id": 82, "text": "微妙香潔。", "ruby": "みみょうこうけつ", "duration": 3.0, "type": "all" },
  { "id": 83, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 84, "text": "極楽国土、", "ruby": "ごくらーこくど", "duration": 3.0, "type": "all" },
  { "id": 85, "text": "成就如是", "ruby": "じょうじゅにょぜ", "duration": 6.0, "type": "slow" },
  { "id": 86, "text": "功徳荘厳。", "ruby": "くどくしょうごん", "duration": 7.0, "type": "slow" },
  { "id": 87, "text": "又舎利弗、", "ruby": "うしゃりほつ", "duration": 3.0, "type": "all" },
  { "id": 88, "text": "彼仏国土、", "ruby": "ひぶっこくど", "duration": 3.0, "type": "all" },
  { "id": 89, "text": "常作天楽。", "ruby": "じょうさてんがく", "duration": 3.0, "type": "all" },
  { "id": 90, "text": "黄金爲地、", "ruby": "おうごんいじ", "duration": 3.0, "type": "all" },
  { "id": 91, "text": "晝夜六時", "ruby": "ちゅうやろくじ", "duration": 3.0, "type": "all" },
  { "id": 92, "text": "而雨曼陀羅華。", "ruby": "にうまんだらけ", "duration": 4.0, "type": "all" },
  { "id": 93, "text": "其国衆生、", "ruby": "ごこくしゅじょう", "duration": 3.0, "type": "all" },
  { "id": 94, "text": "常以清旦、", "ruby": "じょういしょうたん", "duration": 3.0, "type": "all" },
  { "id": 95, "text": "各以衣裓、", "ruby": "かくいえこく", "duration": 3.0, "type": "all" },
  { "id": 96, "text": "盛衆妙華、", "ruby": "じょうしゅみょうけ", "duration": 3.0, "type": "all" },
  { "id": 97, "text": "供養他方、", "ruby": "くようたほう", "duration": 3.0, "type": "all" },
  { "id": 98, "text": "十萬億佛。", "ruby": "じゅうまんのくぶつ", "duration": 3.0, "type": "all" },
  { "id": 99, "text": "即以食時、", "ruby": "そくいじきじ", "duration": 3.0, "type": "all" },
  { "id": 100, "text": "還到本国、", "ruby": "げんとうほんごく", "duration": 3.0, "type": "all" },
  { "id": 101, "text": "飯食経行。", "ruby": "ぼんじききょうぎょう", "duration": 3.5, "type": "all" },
  { "id": 102, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 103, "text": "極楽国土、", "ruby": "ごくらーこくど", "duration": 3.0, "type": "all" },
  { "id": 104, "text": "成就如是", "ruby": "じょうじゅにょぜ", "duration": 6.0, "type": "slow" },
  { "id": 105, "text": "功徳荘厳。", "ruby": "くどくしょうごん", "duration": 7.0, "type": "slow" },
  { "id": 106, "text": "復次舎利弗、", "ruby": "ぶっししゃりほつ", "duration": 3.5, "type": "all" },
  { "id": 107, "text": "彼国常有", "ruby": "ひこくじょうう", "duration": 3.0, "type": "all" },
  { "id": 108, "text": "種種奇妙", "ruby": "しゅじゅきみょう", "duration": 3.0, "type": "all" },
  { "id": 109, "text": "雑色之鳥。", "ruby": "ざっしきしちょう", "duration": 3.0, "type": "all" },
  { "id": 110, "text": "白鵠・孔雀・", "ruby": "びゃっこう くじゃく", "duration": 3.0, "type": "all" },
  { "id": 111, "text": "鸚鵡・舎利・", "ruby": "おうむ しゃり", "duration": 3.0, "type": "all" },
  { "id": 112, "text": "迦陵頻伽・", "ruby": "かりょうびんが", "duration": 3.0, "type": "all" },
  { "id": 113, "text": "共命之鳥。", "ruby": "ぐみょうしちょう", "duration": 3.0, "type": "all" },
  { "id": 114, "text": "是諸衆鳥、", "ruby": "ぜしょしゅちょう", "duration": 3.0, "type": "all" },
  { "id": 115, "text": "昼夜六時", "ruby": "ちゅうやろくじ", "duration": 3.0, "type": "all" },
  { "id": 116, "text": "出和雅音。", "ruby": "すいわげおん", "duration": 3.0, "type": "all" },
  { "id": 117, "text": "其音演暢", "ruby": "ごおんえんちょう", "duration": 3.0, "type": "all" },
  { "id": 118, "text": "五根・五力・", "ruby": "ごこん ごりき", "duration": 3.0, "type": "all" },
  { "id": 119, "text": "七菩提分・", "ruby": "しちぼだいぶん", "duration": 3.0, "type": "all" },
  { "id": 120, "text": "八聖道分、", "ruby": "はっしょうどうぶん", "duration": 3.0, "type": "all" },
  { "id": 121, "text": "如是等法。", "ruby": "にょぜとうほう", "duration": 3.0, "type": "all" },
  { "id": 122, "text": "其土衆生、", "ruby": "ごどしゅじょう", "duration": 3.0, "type": "all" },
  { "id": 123, "text": "聞是音已、", "ruby": "もんぜおんに", "duration": 3.0, "type": "all" },
  { "id": 124, "text": "皆悉念佛", "ruby": "かいしつねんぶつ", "duration": 3.0, "type": "all" },
  { "id": 125, "text": "念法念僧。", "ruby": "ねんぽうねんそう", "duration": 3.0, "type": "all" },
  { "id": 126, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 127, "text": "汝勿謂此鳥", "ruby": "にょもついしちょう", "duration": 3.5, "type": "all" },
  { "id": 128, "text": "實是罪報所生。", "ruby": "じつぜざいほうしょしよう", "duration": 4.0, "type": "all" },
  { "id": 129, "text": "所以者何。", "ruby": "しょいしゃが", "duration": 3.0, "type": "all" },
  { "id": 130, "text": "彼佛国土", "ruby": "ひぶつこくど", "duration": 3.0, "type": "all" },
  { "id": 131, "text": "無三悪趣。", "ruby": "むさんまくしゅ", "duration": 3.0, "type": "all" },
  { "id": 132, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 133, "text": "其佛国土", "ruby": "ごぶっこくど", "duration": 3.0, "type": "all" },
  { "id": 134, "text": "尚無三悪道之名", "ruby": "しょうむさんまくどうしみょう", "duration": 4.0, "type": "all" },
  { "id": 135, "text": "何況有實。", "ruby": "がきょううじつ", "duration": 3.0, "type": "all" },
  { "id": 136, "text": "是諸衆鳥、", "ruby": "ぜしょしゅちょう", "duration": 3.0, "type": "all" },
  { "id": 137, "text": "皆是阿彌陀佛、", "ruby": "かいぜあみだぶつ", "duration": 4.0, "type": "all" },
  { "id": 138, "text": "欲令法音宣流、", "ruby": "よくりょうほうおんせんる", "duration": 4.5, "type": "all" },
  { "id": 139, "text": "変化所作。", "ruby": "へんげしょさ", "duration": 3.0, "type": "all" },
  { "id": 140, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 141, "text": "彼佛国土、", "ruby": "ひぶっこくど", "duration": 3.0, "type": "all" },
  { "id": 142, "text": "微風吹動、", "ruby": "みふうすいどう", "duration": 3.0, "type": "all" },
  { "id": 143, "text": "諸宝行樹、", "ruby": "しょほうごうじゅ", "duration": 3.0, "type": "all" },
  { "id": 144, "text": "及宝羅網、", "ruby": "きゅうほうらもう", "duration": 3.0, "type": "all" },
