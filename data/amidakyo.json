  { "id": 146, "text": "譬如百千種楽", "ruby": "ひにょひゃくせんじゅがく", "duration": 4.0, "type": "all" },
  { "id": 147, "text": "同時倶作。", "ruby": "どうじくさく", "duration": 3.0, "type": "all" },
  { "id": 148, "text": "聞是音者、", "ruby": "もんぜおんじゃ", "duration": 3.0, "type": "all" },
  { "id": 149, "text": "皆自然生", "ruby": "かいじねんじょう", "duration": 3.0, "type": "all" },
  { "id": 150, "text": "念佛、念法、", "ruby": "ねんぶつ ねんぽう", "duration": 3.0, "type": "all" },
  { "id": 151, "text": "念僧之心。", "ruby": "ねんそうししん", "duration": 3.0, "type": "all" },
  { "id": 152, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 153, "text": "其佛国土、", "ruby": "ごぶっこくど", "duration": 3.0, "type": "all" },
