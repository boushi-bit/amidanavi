  { "id": 284, "text": "舎利弗、上方世界、", "ruby": "しゃりほつ じょうほうせかい", "duration": 4.0, "type": "all" },
  { "id": 285, "text": "有梵音佛・宿王佛・", "ruby": "うぼんのんぶつ しゅくおうぶつ", "duration": 4.5, "type": "all" },
  { "id": 286, "text": "香上佛・香光佛・大焔肩佛・", "ruby": "こうじょうぶつ こうこうぶつ だいえんけんぶつ", "duration": 5.0, "type": "all" },
  { "id": 287, "text": "雑色宝華厳身佛・", "ruby": "ざっしきほうけごんしんぶつ", "duration": 5.0, "type": "all" },
  { "id": 288, "text": "娑羅樹王佛・宝華徳佛・", "ruby": "しゃらじゅおうぶつ ほうけとくぶつ", "duration": 4.5, "type": "all" },
  { "id": 289, "text": "見一切義佛・如須弥山佛、", "ruby": "けんいっさいぎぶつ にょしゅみせんぶつ", "duration": 5.0, "type": "all" },
  { "id": 290, "text": "如是等恒河沙数諸佛、", "ruby": "にょぜとうごうがしゃしゅしょぶつ", "duration": 5.0, "type": "all" },
  { "id": 291, "text": "各於其国、出廣長舌相、", "ruby": "かくおごこく すいこうじょうぜっそう", "duration": 5.0, "type": "all" },
