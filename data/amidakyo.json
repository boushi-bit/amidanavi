  { "id": 257, "text": "汝等衆生、當信是稱讚", "ruby": "にょとうしゅじょう とうしんぜしょうさん", "duration": 4.5, "type": "all" },
  { "id": 258, "text": "不可思議功徳一切諸佛所護念経。", "ruby": "ふかしぎくどくいっさいしょぶつしょごねんぎょう", "duration": 6.0, "type": "all" },
  { "id": 259, "text": "舎利弗、西方世界、", "ruby": "しゃりほつ さいほうせかい", "duration": 4.0, "type": "all" },
  { "id": 260, "text": "有無量寿佛・無量相佛・", "ruby": "うむりょうじゅぶつ むりょうそうぶつ", "duration": 5.0, "type": "all" },
  { "id": 261, "text": "無量幢佛・大光佛・", "ruby": "むりょうどうぶつ だいこうぶつ", "duration": 4.5, "type": "all" },
  { "id": 262, "text": "大明佛・宝相佛・浄光佛、", "ruby": "だいみょうぶつ ほうそうぶつ じょうこうぶつ", "duration": 5.0, "type": "all" },
