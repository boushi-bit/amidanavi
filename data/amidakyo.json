  { "id": 164, "text": "是故號阿彌陀。", "ruby": "ぜこごういあみだ", "duration": 4.0, "type": "all" },
  { "id": 165, "text": "又舎利弗、", "ruby": "うしゃりほつ", "duration": 3.0, "type": "all" },
  { "id": 166, "text": "彼佛寿命", "ruby": "ひぶつじゅみょう", "duration": 3.0, "type": "all" },
  { "id": 167, "text": "及其人民", "ruby": "ぎゅうごにんみん", "duration": 3.0, "type": "all" },
  { "id": 168, "text": "無量無辺", "ruby": "むりょうむへん", "duration": 3.0, "type": "all" },
  { "id": 169, "text": "阿僧祇劫。", "ruby": "あそうぎこう", "duration": 3.0, "type": "all" },
  { "id": 170, "text": "故名阿彌陀。", "ruby": "こみょうあみだ", "duration": 3.5, "type": "all" },
  { "id": 171, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 172, "text": "阿彌陀佛、", "ruby": "あみだぶ", "duration": 3.0, "type": "all" },
  { "id": 173, "text": "成佛已来", "ruby": "じょうぶついらい", "duration": 3.0, "type": "all" },
  { "id": 174, "text": "於今十劫。", "ruby": "おこんじっこう", "duration": 3.0, "type": "all" },
  { "id": 175, "text": "又舎利弗、", "ruby": "うしゃりほつ", "duration": 3.0, "type": "all" },
  { "id": 176, "text": "彼佛有無量無辺", "ruby": "ひぶつうむりょうむへん", "duration": 4.5, "type": "all" },
  { "id": 177, "text": "声聞弟子、", "ruby": "しょうもんでし", "duration": 3.0, "type": "all" },
  { "id": 178, "text": "皆阿羅漢。", "ruby": "かいあらかん", "duration": 3.0, "type": "all" },
  { "id": 179, "text": "非是算数", "ruby": "ひぜさんじゅ", "duration": 3.0, "type": "all" },
  { "id": 180, "text": "之所能知。", "ruby": "ししょのうち", "duration": 3.0, "type": "all" },
  { "id": 181, "text": "諸菩薩衆、", "ruby": "しょぼさっしゅ", "duration": 3.0, "type": "all" },
  { "id": 182, "text": "亦復如是。", "ruby": "やくぶにょぜ", "duration": 3.0, "type": "all" },
  { "id": 183, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 184, "text": "彼佛国土、", "ruby": "ひぶっこくど", "duration": 3.0, "type": "all" },
  { "id": 185, "text": "成就如是", "ruby": "じょうじゅにょぜ", "duration": 6.0, "type": "slow" },
  { "id": 186, "text": "功徳荘厳。", "ruby": "くどくしょうごん", "duration": 7.0, "type": "slow" },
  { "id": 187, "text": "又舎利弗、極楽国土、", "ruby": "うしゃりほつ ごくらーこくど", "duration": 5.0, "type": "all" },
  { "id": 188, "text": "衆生生者", "ruby": "しゅじょうしょうじゃ", "duration": 3.0, "type": "all" },
  { "id": 189, "text": "皆是阿鞞跋致。", "ruby": "かいぜあびばっち", "duration": 4.0, "type": "all" },
  { "id": 190, "text": "其中多有", "ruby": "ごちゅうたう", "duration": 3.0, "type": "all" },
  { "id": 191, "text": "一生補處。", "ruby": "いっしょうふしょ", "duration": 3.0, "type": "all" },
  { "id": 192, "text": "其数甚多。", "ruby": "ごしゅじんた", "duration": 3.0, "type": "all" },
  { "id": 193, "text": "非是算数", "ruby": "ひぜさんじゅ", "duration": 3.0, "type": "all" },
  { "id": 194, "text": "所能知之。", "ruby": "しょのうちし", "duration": 3.0, "type": "all" },
  { "id": 195, "text": "但可以無量無辺", "ruby": "たんかいむりょうむへん", "duration": 4.5, "type": "all" },
  { "id": 196, "text": "阿僧祇劫説。", "ruby": "あそうぎこうせつ", "duration": 4.0, "type": "all" },
  { "id": 197, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 198, "text": "衆生聞者、", "ruby": "しゅじょうもんじゃ", "duration": 3.0, "type": "all" },
  { "id": 199, "text": "應當発願", "ruby": "おうとうほつがん", "duration": 3.0, "type": "all" },
  { "id": 200, "text": "願生彼国。", "ruby": "がんしょうひこく", "duration": 3.0, "type": "all" },
  { "id": 201, "text": "所以者何。", "ruby": "しょいしゃが", "duration": 3.0, "type": "all" },
  { "id": 202, "text": "得與如是", "ruby": "とくよにょぜ", "duration": 3.0, "type": "all" },
  { "id": 203, "text": "諸上善人", "ruby": "しょじょうぜんにん", "duration": 3.0, "type": "all" },
  { "id": 204, "text": "倶會一處。", "ruby": "くえいっしょ", "duration": 3.0, "type": "all" },
  { "id": 205, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 206, "text": "不可以少善根", "ruby": "ふかいしょうぜんごん", "duration": 4.0, "type": "all" },
  { "id": 207, "text": "福徳因縁", "ruby": "ふくとくいんねん", "duration": 3.0, "type": "all" },
  { "id": 208, "text": "得生彼国。", "ruby": "とくしょうひこく", "duration": 3.0, "type": "all" },
  { "id": 209, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 210, "text": "若有善男子・善女人、", "ruby": "にゃくうぜんなんし ぜんにょにん", "duration": 5.0, "type": "all" },
  { "id": 211, "text": "聞説阿彌陀佛、", "ruby": "もんせつあみだぶつ", "duration": 4.0, "type": "all" },
  { "id": 212, "text": "執持名號、", "ruby": "しゅうじみょうごう", "duration": 3.0, "type": "all" },
  { "id": 213, "text": "若一日、若二日、", "ruby": "にゃくいちにち にゃくににち", "duration": 4.0, "type": "all" },
  { "id": 214, "text": "若三日、若四日、", "ruby": "にゃくさんにち にゃくしにち", "duration": 4.0, "type": "all" },
  { "id": 215, "text": "若五日、若六日、", "ruby": "にゃくごにち にゃくろくにち", "duration": 4.0, "type": "all" },
  { "id": 216, "text": "若七日、", "ruby": "にゃくしちにち", "duration": 3.0, "type": "all" },
  { "id": 217, "text": "一心不乱、", "ruby": "いっしんふらん", "duration": 3.0, "type": "all" },
  { "id": 218, "text": "其人臨命終時、", "ruby": "ごにんりんみょうしゅうじ", "duration": 4.5, "type": "all" },
  { "id": 219, "text": "阿彌陀佛、", "ruby": "あみだぶつ", "duration": 3.0, "type": "all" },
  { "id": 220, "text": "與諸聖衆", "ruby": "よしょしょうじゅ", "duration": 3.0, "type": "all" },
  { "id": 221, "text": "現在其前。", "ruby": "げんざいごぜん", "duration": 3.0, "type": "all" },
  { "id": 222, "text": "是人終時、", "ruby": "ぜにんじゅうじ", "duration": 3.0, "type": "all" },
  { "id": 223, "text": "心不顛倒、", "ruby": "しんぷてんどう", "duration": 3.0, "type": "all" },
  { "id": 224, "text": "即得往生", "ruby": "そくとくおうじょう", "duration": 3.0, "type": "all" },
  { "id": 225, "text": "阿彌陀佛極楽国土。", "ruby": "あみだぶつごくらーこくど", "duration": 5.0, "type": "all" },
  { "id": 226, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 227, "text": "我見是利、", "ruby": "がけんぜり", "duration": 3.0, "type": "all" },
  { "id": 228, "text": "故説此言。", "ruby": "こせつしごん", "duration": 3.0, "type": "all" },
  { "id": 229, "text": "若有衆生、", "ruby": "にゃくうしゅじょう", "duration": 3.0, "type": "all" },
  { "id": 230, "text": "聞是説者、", "ruby": "もんぜせっしゃ", "duration": 3.0, "type": "all" },
  { "id": 231, "text": "應當発願", "ruby": "おうとうほつがん", "duration": 3.0, "type": "all" },
  { "id": 232, "text": "生彼国土。", "ruby": "しょうひこくど", "duration": 3.0, "type": "all" },
  { "id": 233, "text": "舎利弗、", "ruby": "しゃりほつ", "duration": 2.5, "type": "all" },
  { "id": 234, "text": "如我今者", "ruby": "にょがこんじゃ", "duration": 3.0, "type": "all" },
  { "id": 235, "text": "讃歎阿彌陀佛", "ruby": "さんだんあみだぶつ", "duration": 4.0, "type": "all" },
  { "id": 236, "text": "不可思議功徳、", "ruby": "ふかしぎくどく", "duration": 4.0, "type": "all" },
  { "id": 237, "text": "東方亦有、", "ruby": "とうぼうやくう", "duration": 3.0, "type": "all" },
  { "id": 238, "text": "阿閦鞞佛・須弥相佛・", "ruby": "あしゅくびぶつ しゅみそうぶつ", "duration": 4.5, "type": "all" },
  { "id": 239, "text": "大須弥佛・須弥光佛・", "ruby": "だいしゅみぶつ しゅみこうぶつ", "duration": 4.5, "type": "all" },
  { "id": 240, "text": "妙音佛、", "ruby": "みょうおんぶつ", "duration": 3.0, "type": "all" },
  { "id": 241, "text": "如是等恒河沙数諸佛、", "ruby": "にょぜとうごうがしゃしゅしょぶつ", "duration": 5.0, "type": "all" },
  { "id": 242, "text": "各於其国、", "ruby": "かくおごこく", "duration": 3.0, "type": "all" },
  { "id": 243, "text": "出廣長舌相、", "ruby": "すいこうじょうぜっそう", "duration": 4.0, "type": "all" },
  { "id": 244, "text": "徧覆三千大千世界、", "ruby": "へんぷさんぜんだいせんせかい", "duration": 5.0, "type": "all" },
  { "id": 245, "text": "説誠實言。", "ruby": "せつじょうじつごん", "duration": 3.5, "type": "all" },
  { "id": 246, "text": "汝等衆生、", "ruby": "にょとうしゅじょう", "duration": 3.0, "type": "all" },
  { "id": 247, "text": "當信是稱讚", "ruby": "とうしんぜしょうさん", "duration": 3.5, "type": "all" },
  { "id": 248, "text": "不可思議功徳", "ruby": "ふかしぎくどく", "duration": 4.0, "type": "all" },
  { "id": 249, "text": "一切諸佛所護念経。", "ruby": "いっさいしょぶつしょごねんぎょう", "duration": 5.0, "type": "all" },
  { "id": 250, "text": "舎利弗、南方世界、", "ruby": "しゃりほつ なんぽうせかい", "duration": 4.0, "type": "all" },
  { "id": 251, "text": "有日月燈佛・名聞光佛・", "ruby": "うにちがっとうぶつ みょうもんこうぶつ", "duration": 5.0, "type": "all" },
  { "id": 252, "text": "大焔肩佛・須弥燈佛・", "ruby": "だいえんけんぶつ しゅみとうぶつ", "duration": 4.5, "type": "all" },
  { "id": 253, "text": "無量精進佛、", "ruby": "むりょうしょうじんぶつ", "duration": 4.0, "type": "all" },
  { "id": 254, "text": "如是等恒河沙数諸佛、", "ruby": "にょぜとうごうがしゃしゅしょぶつ", "duration": 5.0, "type": "all" },
  { "id": 255, "text": "各於其国、出廣長舌相、", "ruby": "かくおごこく すいこうじょうぜっそう", "duration": 5.0, "type": "all" },
